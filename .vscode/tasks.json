{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start Backend (FastAPI)",
            "type": "shell",
            "command": "${workspaceFolder}/hubert_env/Scripts/python.exe",
            "args": [
                "main.py"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "group": "nli-kiosk",
                "reveal": "always",
                "panel": "shared"
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "Start Frontend (Next.js)",
            "type": "shell",
            "command": "npm",
            "args": [
                "run",
                "dev"
            ],
            "options": {
                "cwd": "${workspaceFolder}/kiosk-next"
            },
            "presentation": {
                "group": "nli-kiosk",
                "reveal": "always",
                "panel": "shared"
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "Start All (Backend + Frontend)",
            "dependsOn": [
                "Start Backend (FastAPI)",
                "Start Frontend (Next.js)"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}
